generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  password            String
  name                String
  role                String   @default("VIEWER")
  mfaSecret           String?  @map("mfa_secret")
  mfaEnabled          Boolean  @default(false) @map("mfa_enabled")
  mfaBackupCodes      String?  @map("mfa_backup_codes")
  passwordLastChanged DateTime @default(now()) @map("password_last_changed")
  sessions            Session[]
  trustedDevices      TrustedDevice[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  posts               Post[]
}

model Post {
  id                String     @id @default(cuid())
  title             String
  subtitle          String?
  slug              String     @unique
  excerpt           String?
  summary           String?
  summaryTitle      String?
  status            String     @default("DRAFT")
  featured          Boolean    @default(false)
  featuredOrder     Int?
  coverImage        String?
  coverImageAlt     String?
  coverImageCaption String?
  views             Int        @default(0)
  likes             Int        @default(0)
  dislikes          Int        @default(0)
  shares            Int        @default(0)
  reactionHistoric  Int        @default(0)
  reactionBrilliant Int        @default(0)
  reactionInsightful Int       @default(0)
  comments          Comment[]
  readingTime       Int        @default(0)
  wordCount         Int        @default(0)
  authorId          String
  seoTitle          String?
  seoDescription    String?
  seoKeywords       String?
  canonicalUrl      String?
  ogTitle           String?
  ogDescription     String?
  ogImage           String?
  twitterImage      String?
  schemaType        String     @default("Article")
  robotsIndex       Boolean    @default(true)
  completionQuote   String?
  completionQuoteAuthor String?
  publishedAt       DateTime?
  scheduledAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  blocks            Block[]
  categories        Category[] @relation("PostToCategory")
  author            User       @relation(fields: [authorId], references: [id])
  revisions         Revision[]
  tags              Tag[]      @relation("PostToTag")
  pageViews         PageView[]

  @@index([slug])
  @@index([status])
}

model Block {
  id         String   @id @default(cuid())
  postId     String
  type       String
  content    String
  orderIndex Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([orderIndex])
}

model Revision {
  id        String   @id @default(cuid())
  postId    String
  snapshot  String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Category {
  id            String     @id @default(cuid())
  name          String     @unique
  slug          String     @unique
  icon          String?
  color         String?
  parentId      String?
  parent        Category?  @relation("SubCategories", fields: [parentId], references: [id])
  subCategories Category[] @relation("SubCategories")
  posts         Post[]     @relation("PostToCategory")
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[] @relation("PostToTag")
}

model Folder {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String?  @default("#38bdf8")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  media     Media[]
}

model Media {
  id               String   @id @default(cuid())
  filename         String
  path             String
  mimetype         String   @default("image/webp")
  size             Int
  originalFormat   String?
  originalSize     Int?
  optimizedSize    Int?
  compressionRatio Float?
  width            Int?
  height           Int?
  folderId         String?
  folder           Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@index([folderId])
  @@index([createdAt])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Feedback {
  id        String   @id @default(cuid())
  name      String
  email     String
  type      String   @default("love")
  message   String
  createdAt DateTime @default(now())
}

model Quote {
  id          String   @id @default(cuid())
  text        String
  translation String?
  meaning     String?
  author      String
  category    String
  createdAt   DateTime @default(now())
}

model NewsletterSubscriber {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                      String    @unique
  status                     String    // 'pending' | 'active' | 'unsubscribed'
  verificationToken          String?   @unique @map("verification_token")
  verificationTokenExpiresAt DateTime? @map("verification_token_expires_at")
  unsubscribeToken           String?   @unique @map("unsubscribe_token")
  subscribedAt               DateTime  @default(now()) @map("subscribed_at")
  verifiedAt                 DateTime? @map("verified_at")
  unsubscribedAt             DateTime? @map("unsubscribed_at")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  @@map("newsletter_subscribers")
}

model SiteConfig {
  key   String @id
  value String
}

model GlossaryTerm {
  id         String   @id @default(cuid())
  term       String   @unique
  definition String
  category   String   // 'history' | 'technology' | 'cybersecurity'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SecurityLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  event     String   // 'LOGIN_SUCCESS', 'LOGIN_FAILURE', 'MFA_SETUP', 'MFA_FAILED', etc.
  email     String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  browser   String?
  os        String?
  location  String?
}

model PageView {
  id        String   @id @default(cuid())
  postId    String?
  slug      String
  timestamp DateTime @default(now())
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  browser   String?
  os        String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([timestamp])
  @@index([slug])
}

model Comment {
  id          String   @id @default(uuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorName  String
  authorEmail String
  content     String
  createdAt   DateTime @default(now())
  isHidden    Boolean  @default(false)
  adminReply  String?
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  browser      String?
  os           String?
  deviceName   String?
  ipAddress    String?
  country      String?
  city         String?
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())
  isValid      Boolean  @default(true)
}

model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId   String   @unique
  deviceName String
  browser    String
  os         String
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
}

